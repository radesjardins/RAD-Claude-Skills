# Enforce consistent line endings across platforms
# JSON files must be LF — CRLF causes parse failures in marketplace sync
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# PowerShell
*.ps1 text eol=crlf

# Prevent binary diff noise
*.png binary
*.jpg binary
*.gif binary
*.ico binary
