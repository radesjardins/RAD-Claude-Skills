# ──────────────────────────────────────────────────────────────────────────────
# .dockerignore for Node.js projects
#
# CRITICAL: Create this file before any Dockerfile COPY instruction.
# Without it, "COPY . ." sends the entire project to the Docker daemon,
# including node_modules (OS-specific binaries), .git history, and .env secrets.
#
# Usage: copy this file to your project root and rename to .dockerignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
# NEVER copy host node_modules — they may contain OS-specific native binaries
# (e.g., compiled for macOS/Windows but the container runs Linux)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-lock.yaml.lock
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml

# ── Source control ─────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.gitmodules

# ── Local build artifacts ──────────────────────────────────────────────────────
# Let Docker build these fresh — never copy local builds into the image
# (stale artifacts can cause hard-to-debug container issues)
dist/
build/
.next/
out/
.nuxt/
.output/
.cache/
.turbo/
.nx/cache/
storybook-static/

# ── Secrets and sensitive local configuration ─────────────────────────────────
# If any of these are copied into the image, they are permanently baked
# into the image layer history — accessible via "docker history"
.env
.env.*
!.env.example        # Allow the example/template env file
.npmrc               # May contain auth tokens for private packages
aws.json
*.pem
*.key
*.cert
*.p12
*.pfx
secrets/
credentials/

# ── Docker files ───────────────────────────────────────────────────────────────
Dockerfile
Dockerfile.*
docker-compose*.yml
compose.yaml
.dockerignore

# ── Documentation ─────────────────────────────────────────────────────────────
README.md
CHANGELOG.md
CONTRIBUTING.md
docs/
*.md

# ── Editor and OS artifacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/
*.swp
*.swo
*~

# ── Test artifacts ────────────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
__tests__/
*.test.ts
*.test.js
*.spec.ts
*.spec.js
jest.config.*
vitest.config.*
playwright.config.*
.env.test

# ── CI/CD ─────────────────────────────────────────────────────────────────────
.github/
.gitlab/
.circleci/
.husky/

# ── Miscellaneous ──────────────────────────────────────────────────────────────
*.local
.eslintcache
.stylelintcache
tsconfig.tsbuildinfo
